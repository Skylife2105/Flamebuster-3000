#include <Arduino.h>
#include <SCServo.h>
#include <Preferences.h>

SMS_STS st;
Preferences prefs;

// ---------- Anpassen ----------
constexpr uint8_t SERVO_ID = 2;

constexpr int SERVO_RX = 18;
constexpr int SERVO_TX = 17;
constexpr int POT_PIN  = 4;

constexpr int SERVO_BAUD = 1000000;

constexpr uint32_t SPEED_COMMAND_INTERVAL_MS = 50;
constexpr int SPEED_CHANGE_THRESHOLD = 10;

int lastPhysicalSpeedCommand = 99999;
uint32_t lastSpeedCommandMs = 0;

// Kalibrierung
int potMinRaw = 500;
int potMaxRaw = 3500;
float jointMinDeg = 0.0f;
float jointMaxDeg = 150.0f;

// Regler
float kp = 18.0f;
int minSpeed = 35;
int maxSpeed = 500;
int activeAcc = 8;
float toleranceDeg = 0.35f;

// Sicherheit
constexpr float HARD_MARGIN_DEG = 0.4f;
constexpr float LIMIT_STOP_MARGIN_DEG = 0.8f;
constexpr uint32_t CONTROL_INTERVAL_MS = 5;
constexpr uint32_t MOVE_TIMEOUT_MS = 20000;

// Wenn Richtung falsch ist: per Terminal "dir -1"
int servoDirection = 1;

String inputLine;
String motionInputLine;
bool emergencyLatched = false;

// ---------- Poti ----------

int readPotRawAveraged(uint16_t samples = 8) {
  uint32_t sum = 0;
  for (uint16_t i = 0; i < samples; i++) {
    sum += analogRead(POT_PIN);
    delayMicroseconds(200);
  }
  return sum / samples;
}

float rawToJointDegUnclamped(int raw) {
  if (potMinRaw == potMaxRaw) return NAN;

  float t = float(raw - potMinRaw) / float(potMaxRaw - potMinRaw);
  return jointMinDeg + t * (jointMaxDeg - jointMinDeg);
}

float readJointDeg() {
  return rawToJointDegUnclamped(readPotRawAveraged());
}

bool isHardOutOfRange(float deg) {
  return deg < jointMinDeg - HARD_MARGIN_DEG || deg > jointMaxDeg + HARD_MARGIN_DEG;
}

bool movingTowardLimit(float deg, int speed) {
  if (deg <= jointMinDeg + LIMIT_STOP_MARGIN_DEG && speed < 0) return true;
  if (deg >= jointMaxDeg - LIMIT_STOP_MARGIN_DEG && speed > 0) return true;
  return false;
}

// ---------- Servo ----------

void driveSpeed(int logicalSpeed, bool force = false) {
  logicalSpeed = constrain(logicalSpeed, -maxSpeed, maxSpeed);
  int physicalSpeed = logicalSpeed * servoDirection;

  bool changedEnough = abs(physicalSpeed - lastPhysicalSpeedCommand) >= SPEED_CHANGE_THRESHOLD;
  bool intervalPassed = millis() - lastSpeedCommandMs >= SPEED_COMMAND_INTERVAL_MS;

  if (force || (changedEnough && intervalPassed)) {
    st.WriteSpe(SERVO_ID, physicalSpeed, activeAcc);
    lastPhysicalSpeedCommand = physicalSpeed;
    lastSpeedCommandMs = millis();
  }
}

void stopServo() {
  st.WriteSpe(SERVO_ID, 0, 0);
  lastPhysicalSpeedCommand = 0;
  lastSpeedCommandMs = millis();
  delay(20);
}

void emergencyStop(const char *reason) {
  stopServo();
  emergencyLatched = true;
  Serial.print("NOT-STOPP: ");
  Serial.println(reason);
  Serial.println("Bewegung gesperrt. Erst 'clear' senden.");
}

bool safetyCheck(const char *context) {
  float deg = readJointDeg();

  if (isnan(deg)) {
    emergencyStop("Poti-Kalibrierung ungueltig");
    return false;
  }

  if (isHardOutOfRange(deg)) {
    Serial.print("Winkel ausserhalb Bereich bei ");
    Serial.print(context);
    Serial.print(": ");
    Serial.println(deg, 3);
    emergencyStop("Poti-Randwert ueberschritten");
    return false;
  }

  return true;
}

void setVelocityMode() {
  st.EnableTorque(SERVO_ID, 0);
  delay(100);

  st.WheelMode(SERVO_ID);
  delay(100);

  st.EnableTorque(SERVO_ID, 1);
  driveSpeed(0, true);

  Serial.println("Geschwindigkeitsmodus gesetzt.");
}

bool userRequestedStopDuringMotion() {
  while (Serial.available()) {
    char c = Serial.read();

    if (c == '\n' || c == '\r') {
      motionInputLine.trim();
      if (motionInputLine == "stop" || motionInputLine == "s") {
        motionInputLine = "";
        emergencyStop("Manueller Stop");
        return true;
      }
      motionInputLine = "";
    } else {
      motionInputLine += c;
    }
  }
  return false;
}

// ---------- Bewegung nur per Poti-Regelung ----------

int speedFromError(float errorDeg) {
  float absError = fabsf(errorDeg);

  if (absError <= toleranceDeg) return 0;

  int speed = int(absError * kp);

  if (absError > 1.0f) {
    speed = max(speed, minSpeed);
  }

  if (absError < 8.0f) {
    speed = min(speed, 220);
  }

  if (absError < 4.0f) {
    speed = min(speed, 130);
  }

  if (absError < 2.0f) {
    speed = min(speed, 70);
  }

  speed = constrain(speed, 0, maxSpeed);
  if (errorDeg < 0) speed = -speed;

  return speed;
}

void moveToByPot(float targetDeg) {
  if (emergencyLatched) {
    Serial.println("Gesperrt durch Not-Stopp. Erst 'clear' senden.");
    return;
  }

  targetDeg = constrain(targetDeg, jointMinDeg, jointMaxDeg);

  if (!safetyCheck("go start")) return;

  uint32_t started = millis();
  uint32_t lastPrint = 0;

  while (true) {
    if (userRequestedStopDuringMotion()) return;

    float currentDeg = readJointDeg();

    if (isnan(currentDeg)) {
      emergencyStop("Poti ungueltig");
      return;
    }

    if (isHardOutOfRange(currentDeg)) {
      emergencyStop("Poti-Randwert erreicht");
      return;
    }

    float error = targetDeg - currentDeg;

    if (fabsf(error) <= toleranceDeg) {
      stopServo();
      Serial.print("Ziel erreicht. Ist=");
      Serial.println(currentDeg, 3);
      return;
    }

    int speed = speedFromError(error);

    if (movingTowardLimit(currentDeg, speed)) {
      emergencyStop("Randwert-Sicherheitszone erreicht");
      return;
    }

    driveSpeed(speed);

    if (millis() - started > MOVE_TIMEOUT_MS) {
      emergencyStop("Timeout bei Bewegung");
      return;
    }

    if (millis() - lastPrint > 200) {
      Serial.print("Ist=");
      Serial.print(currentDeg, 3);
      Serial.print(" Ziel=");
      Serial.print(targetDeg, 3);
      Serial.print(" Fehler=");
      Serial.print(error, 3);
      Serial.print(" Speed=");
      Serial.println(speed);
      lastPrint = millis();
    }

    delay(CONTROL_INTERVAL_MS);
  }
}

void moveRelativeByPot(float deltaDeg) {
  if (!safetyCheck("rel start")) return;

  float currentDeg = readJointDeg();
  float targetDeg = constrain(currentDeg + deltaDeg, jointMinDeg, jointMaxDeg);

  moveToByPot(targetDeg);
}

// ---------- Kalibrierung ----------

void saveCalibration() {
  prefs.begin("joint", false);
  prefs.putInt("potMin", potMinRaw);
  prefs.putInt("potMax", potMaxRaw);
  prefs.putFloat("degMin", jointMinDeg);
  prefs.putFloat("degMax", jointMaxDeg);
  prefs.putInt("dir", servoDirection);
  prefs.end();
  Serial.println("Kalibrierung gespeichert.");
}

void loadCalibration() {
  prefs.begin("joint", true);
  potMinRaw = prefs.getInt("potMin", potMinRaw);
  potMaxRaw = prefs.getInt("potMax", potMaxRaw);
  jointMinDeg = prefs.getFloat("degMin", jointMinDeg);
  jointMaxDeg = prefs.getFloat("degMax", jointMaxDeg);
  servoDirection = prefs.getInt("dir", servoDirection);
  prefs.end();
}

// ---------- Ausgabe ----------

void printStatus() {
  int raw = readPotRawAveraged(16);
  float deg = rawToJointDegUnclamped(raw);

  Serial.print("Poti raw=");
  Serial.print(raw);
  Serial.print(" Winkel=");
  Serial.print(deg, 3);
  Serial.print(" deg Bereich raw[");
  Serial.print(potMinRaw);
  Serial.print(", ");
  Serial.print(potMaxRaw);
  Serial.print("] deg[");
  Serial.print(jointMinDeg, 3);
  Serial.print(", ");
  Serial.print(jointMaxDeg, 3);
  Serial.print("] kp=");
  Serial.print(kp, 2);
  Serial.print(" minSpeed=");
  Serial.print(minSpeed);
  Serial.print(" maxSpeed=");
  Serial.print(maxSpeed);
  Serial.print(" acc=");
  Serial.print(activeAcc);
  Serial.print(" dir=");
  Serial.print(servoDirection);
  Serial.print(" emergency=");
  Serial.println(emergencyLatched ? "JA" : "nein");
}

void printRead() {
  Serial.print("Ping: ");
  Serial.println(st.Ping(SERVO_ID));
  Serial.print("Mode: ");
  Serial.println(st.ReadMode(SERVO_ID));
  Serial.print("Pos: ");
  Serial.println(st.ReadPos(SERVO_ID));
  Serial.print("Speed: ");
  Serial.println(st.ReadSpeed(SERVO_ID));
  Serial.print("Voltage: ");
  Serial.println(st.ReadVoltage(SERVO_ID));
  Serial.print("Temp: ");
  Serial.println(st.ReadTemper(SERVO_ID));
}

void printHelp() {
  Serial.println();
  Serial.println("Befehle:");
  Serial.println("  status            Poti/Winkel/Reglerwerte");
  Serial.println("  read              Servo-Werte lesen");
  Serial.println("  raw               Poti-Rohwerte streamen");
  Serial.println("  setmin            aktuellen Poti-Wert als unteren Rand setzen");
  Serial.println("  setmax            aktuellen Poti-Wert als oberen Rand setzen");
  Serial.println("  range 0 150       Winkelbereich setzen");
  Serial.println("  save              Kalibrierung speichern");
  Serial.println("  mode              Geschwindigkeitsmodus setzen");
  Serial.println("  go 75             per Poti-Regelung auf Winkel fahren");
  Serial.println("  rel 10            per Poti-Regelung relativ bewegen");
  Serial.println("  stop / s          sofort stoppen");
  Serial.println("  clear             Not-Stopp entsperren");
  Serial.println("  kp 18             Reglerstaerke setzen");
  Serial.println("  minspeed 35       Mindestgeschwindigkeit");
  Serial.println("  maxspeed 500      Maximalgeschwindigkeit");
  Serial.println("  acc 8             Beschleunigung");
  Serial.println("  tol 0.35          Ziel-Toleranz in Grad");
  Serial.println("  dir 1 / dir -1    Richtung setzen");
  Serial.println();
}

// ---------- Kommandos ----------

void handleCommand(String cmd) {
  cmd.trim();
  if (cmd.length() == 0) return;

  if (cmd == "help") {
    printHelp();

  } else if (cmd == "status") {
    printStatus();

  } else if (cmd == "read") {
    printRead();

  } else if (cmd == "raw") {
    uint32_t started = millis();
    while (millis() - started < 5000) {
      Serial.println(readPotRawAveraged(8));
      delay(100);
    }

  } else if (cmd == "setmin") {
    potMinRaw = readPotRawAveraged(80);
    Serial.print("potMinRaw = ");
    Serial.println(potMinRaw);

  } else if (cmd == "setmax") {
    potMaxRaw = readPotRawAveraged(80);
    Serial.print("potMaxRaw = ");
    Serial.println(potMaxRaw);

  } else if (cmd.startsWith("range ")) {
    float a, b;
    if (sscanf(cmd.c_str(), "range %f %f", &a, &b) == 2 && b > a) {
      jointMinDeg = a;
      jointMaxDeg = b;
      Serial.println("Winkelbereich gesetzt.");
      printStatus();
    } else {
      Serial.println("Format: range 0 150");
    }

  } else if (cmd == "save") {
    saveCalibration();

  } else if (cmd == "mode") {
    setVelocityMode();

  } else if (cmd.startsWith("go ")) {
    float target;
    if (sscanf(cmd.c_str(), "go %f", &target) == 1) {
      moveToByPot(target);
    } else {
      Serial.println("Format: go 75");
    }

  } else if (cmd.startsWith("rel ")) {
    float delta;
    if (sscanf(cmd.c_str(), "rel %f", &delta) == 1) {
      moveRelativeByPot(delta);
    } else {
      Serial.println("Format: rel -10");
    }

  } else if (cmd == "stop" || cmd == "s") {
    stopServo();
    Serial.println("Stop.");

  } else if (cmd == "clear") {
    emergencyLatched = false;
    Serial.println("Not-Stopp entsperrt.");
    printStatus();

  } else if (cmd.startsWith("kp ")) {
    float v;
    if (sscanf(cmd.c_str(), "kp %f", &v) == 1) {
      kp = constrain(v, 1.0f, 100.0f);
      Serial.print("kp = ");
      Serial.println(kp, 2);
    }

  } else if (cmd.startsWith("minspeed ")) {
    int v;
    if (sscanf(cmd.c_str(), "minspeed %d", &v) == 1) {
      minSpeed = constrain(v, 1, maxSpeed);
      Serial.print("minSpeed = ");
      Serial.println(minSpeed);
    }

  } else if (cmd.startsWith("maxspeed ")) {
    int v;
    if (sscanf(cmd.c_str(), "maxspeed %d", &v) == 1) {
      maxSpeed = constrain(v, minSpeed, 3000);
      Serial.print("maxSpeed = ");
      Serial.println(maxSpeed);
    }

  } else if (cmd.startsWith("acc ")) {
    int v;
    if (sscanf(cmd.c_str(), "acc %d", &v) == 1) {
      activeAcc = constrain(v, 0, 254);
      Serial.print("ACC = ");
      Serial.println(activeAcc);
    }

  } else if (cmd.startsWith("tol ")) {
    float v;
    if (sscanf(cmd.c_str(), "tol %f", &v) == 1) {
      toleranceDeg = constrain(v, 0.05f, 3.0f);
      Serial.print("Toleranz = ");
      Serial.println(toleranceDeg, 3);
    }

  } else if (cmd.startsWith("dir ")) {
    int v;
    if (sscanf(cmd.c_str(), "dir %d", &v) == 1 && (v == 1 || v == -1)) {
      servoDirection = v;
      Serial.print("Richtung = ");
      Serial.println(servoDirection);
    } else {
      Serial.println("Format: dir 1 oder dir -1");
    }

  } else {
    Serial.println("Unbekannter Befehl. Tippe: help");
  }
}

void setup() {
  analogReadResolution(12);
  analogSetPinAttenuation(POT_PIN, ADC_11db);

  Serial.begin(115200);
  delay(1000);

  Serial1.begin(SERVO_BAUD, SERIAL_8N1, SERVO_RX, SERVO_TX);
  st.pSerial = &Serial1;

  loadCalibration();

  Serial.println();
  Serial.println("ESP32S3 ST3215 Poti-geregelter Gelenk-Test");
  printHelp();
  printStatus();
}

void loop() {
  while (Serial.available()) {
    char c = Serial.read();

    if (c == '\n' || c == '\r') {
      handleCommand(inputLine);
      inputLine = "";
    } else {
      inputLine += c;
    }
  }
}
