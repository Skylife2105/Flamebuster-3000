// ============================================================
// KOMMANDOS
// ============================================================
void handleCommand(String cmd) {
  cmd.trim();
  if (cmd.length() == 0) return;

  String upper = cmd;
  upper.toUpperCase();

  if (upper == "STREAM") {
    streamMode = true;
    Serial.println("INFO binary stream enabled");

  } else if (upper == "TEXT") {
    streamMode = false;
    Serial.println("INFO text diagnostic mode enabled");

  } else if (upper == "RESETCAM") {
    streamMode = false;
    cameraConfigured = false;
    Serial.println("INFO camera reset requested");

  } else if (cmd == "help") {
    printHelp();

  } else if (cmd == "status") {
    printStatus();

  } else if (cmd == "read") {
    printReadAll();

  } else if (cmd.startsWith("read ")) {
    int id;
    if (sscanf(cmd.c_str(), "read %d", &id) == 1 && id >= 1 && id <= 4) {
      printReadServo(uint8_t(id));
    } else {
      Serial.println("Format: read 1");
    }

  } else if (cmd == "raw") {
    uint32_t started = millis();
    while (millis() - started < 5000) {
      Serial.println(readPotRawAveraged(8));
      delay(100);
    }

  } else if (cmd == "setmin") {
    potMinRaw = readPotRawAveraged(80);
    Serial.print("potMinRaw = ");
    Serial.println(potMinRaw);

  } else if (cmd == "setmax") {
    potMaxRaw = readPotRawAveraged(80);
    Serial.print("potMaxRaw = ");
    Serial.println(potMaxRaw);

  } else if (cmd.startsWith("range ")) {
    float a, b;
    if (sscanf(cmd.c_str(), "range %f %f", &a, &b) == 2 && b > a) {
      jointMinDeg = a;
      jointMaxDeg = b;
      Serial.println("Servo 2 Winkelbereich gesetzt.");
      printStatus();
    } else {
      Serial.println("Format: range 0 125");
    }

  } else if (cmd == "save") {
    saveCalibration();

  } else if (cmd == "mode") {
    setServo2VelocityMode();

  } else if (cmd == "posmode all") {
    setPositionMode(1);
    setPositionMode(3);
    setPositionMode(4);

  } else if (cmd.startsWith("posmode ")) {
    int id;
    if (sscanf(cmd.c_str(), "posmode %d", &id) == 1) {
      setPositionMode(uint8_t(id));
    } else {
      Serial.println("Format: posmode 1");
    }

  } else if (cmd == "track start") {
    startTracking();

  } else if (cmd == "track stop") {
    stopTrackingOnly();

  } else if (cmd == "track status") {
    printStatus();

  } else if (cmd.startsWith("trackdir1 ")) {
    int v;
    if (sscanf(cmd.c_str(), "trackdir1 %d", &v) == 1 && (v == 1 || v == -1)) {
      trackServo1Sign = v;
      Serial.print("trackServo1Sign = ");
      Serial.println(trackServo1Sign);
    } else {
      Serial.println("Format: trackdir1 1 oder trackdir1 -1");
    }

  } else if (cmd.startsWith("trackdir4 ")) {
    int v;
    if (sscanf(cmd.c_str(), "trackdir4 %d", &v) == 1 && (v == 1 || v == -1)) {
      trackServo4Sign = v;
      Serial.print("trackServo4Sign = ");
      Serial.println(trackServo4Sign);
    } else {
      Serial.println("Format: trackdir4 1 oder trackdir4 -1");
    }

  } else if (cmd.startsWith("go ")) {
    float target;
    if (sscanf(cmd.c_str(), "go %f", &target) == 1) {
      trackingActive = false;
      moveToByPot(target);
    } else {
      Serial.println("Format: go 75");
    }

  } else if (cmd.startsWith("rel ")) {
    float delta;
    if (sscanf(cmd.c_str(), "rel %f", &delta) == 1) {
      trackingActive = false;
      moveRelativeByPot(delta);
    } else {
      Serial.println("Format: rel -10");
    }

  } else if (cmd.startsWith("servo ")) {
    int id;
    float target;
    if (sscanf(cmd.c_str(), "servo %d %f", &id, &target) == 2) {
      if (id == 1 || id == 4) {
        trackingActive = false;
      }
      movePositionServo(uint8_t(id), target);
    } else {
      Serial.println("Format: servo 3 220");
    }

  } else if (cmd == "stop" || cmd == "s") {
    stopAllServos();
    Serial.println("Stop.");

  } else if (cmd == "clear") {
    emergencyLatched = false;
    Serial.println("Not-Stopp entsperrt.");
    printStatus();

  } else if (cmd.startsWith("kp ")) {
    float v;
    if (sscanf(cmd.c_str(), "kp %f", &v) == 1) {
      kp = constrain(v, 1.0f, 100.0f);
      Serial.print("kp = ");
      Serial.println(kp, 2);
    }

  } else if (cmd.startsWith("minspeed ")) {
    int v;
    if (sscanf(cmd.c_str(), "minspeed %d", &v) == 1) {
      minSpeed = constrain(v, 1, maxSpeed);
      Serial.print("minSpeed = ");
      Serial.println(minSpeed);
    }

  } else if (cmd.startsWith("maxspeed ")) {
    int v;
    if (sscanf(cmd.c_str(), "maxspeed %d", &v) == 1) {
      maxSpeed = constrain(v, minSpeed, 3000);
      Serial.print("maxSpeed = ");
      Serial.println(maxSpeed);
    }

  } else if (cmd.startsWith("acc ")) {
    int v;
    if (sscanf(cmd.c_str(), "acc %d", &v) == 1) {
      activeAcc = constrain(v, 0, 254);
      Serial.print("ACC = ");
      Serial.println(activeAcc);
    }

  } else if (cmd.startsWith("tol ")) {
    float v;
    if (sscanf(cmd.c_str(), "tol %f", &v) == 1) {
      toleranceDeg = constrain(v, 0.05f, 3.0f);
      Serial.print("Toleranz = ");
      Serial.println(toleranceDeg, 3);
    }

  } else if (cmd.startsWith("dir ")) {
    int v;
    if (sscanf(cmd.c_str(), "dir %d", &v) == 1 && (v == 1 || v == -1)) {
      servoDirection = v;
      Serial.print("Richtung = ");
      Serial.println(servoDirection);
    } else {
      Serial.println("Format: dir 1 oder dir -1");
    }

  } else {
    Serial.println("Unbekannter Befehl. Tippe: help");
  }
}

void handleSerialCommands() {
  while (Serial.available()) {
    char c = Serial.read();

    if (c == '\n' || c == '\r') {
      handleCommand(inputLine);
      inputLine = "";
    } else {
      inputLine += c;
    }
  }
}

// ============================================================
// SETUP / LOOP
// ============================================================
void setup() {
  pinMode(PIN_RESET, OUTPUT);
  pinMode(PIN_READY, INPUT);
  pinMode(PIN_SS, OUTPUT);
  digitalWrite(PIN_SS, HIGH);
  digitalWrite(PIN_RESET, HIGH);

  analogReadResolution(12);
  analogSetPinAttenuation(POT_PIN, ADC_11db);

  Serial.begin(SERIAL_BAUD);
  delay(1200);

  Serial.println();
  Serial.println("========================================");
  Serial.println("THERMAL TRACKING + ST3215 ROBOT ARM");
  Serial.println("Baud: 921600");
  Serial.println("Viewer: STREAM bleibt kompatibel");
  Serial.println("Tracking: track start / track stop");
  Serial.println("========================================");

  Wire.begin(PIN_SDA, PIN_SCL);
  Wire.setClock(100000);

  SPI.begin(PIN_CLK, PIN_MISO, PIN_MOSI, PIN_SS);

  Serial1.begin(SERVO_BAUD, SERIAL_8N1, SERVO_RX, SERVO_TX);
  st.pSerial = &Serial1;

  loadCalibration();

  resetCamera();
  delay(700);

  cameraConfigured = configureCamera();
  if (!cameraConfigured) {
    Serial.println("ERR setup failed; check camera wiring and power");
  }

  printHelp();
  printStatus();
}

void loop() {
  handleSerialCommands();
  periodicFailsafeCheck();

  if (!cameraConfigured) {
    if (millis() - lastConfigureAttemptMs > 2000) {
      lastConfigureAttemptMs = millis();
      Serial.println("RETRY camera setup");
      resetCamera();
      delay(700);
      cameraConfigured = configureCamera();
    }
    return;
  }

  if (!streamMode && millis() - lastStatusReportMs > 2000) {
    lastStatusReportMs = millis();
    printStatusReport("LIVE STATUS");
  }

  if (!waitForFrameReady(1500)) {
    Serial.println("FRAME ERROR | timeout waiting for DATA_READY; restarting stream");
    printStatusReport("FRAME TIMEOUT DETAIL");
    i2cWrite8(REG_FRAME_MODE, 0);
    delay(50);
    if (!i2cWrite8(REG_FRAME_MODE, FRAME_MODE_NO_HEADER | FRAME_MODE_CONTINUOUS)) {
      Serial.println("CAMERA ERROR | stream restart failed; retrying camera setup");
      cameraConfigured = false;
    }
    return;
  }

  uint16_t minValue = 0;
  uint16_t maxValue = 0;
  if (!readThermalFrame(minValue, maxValue)) {
    Serial.println("FRAME ERROR | invalid min/max range from SPI data");
    return;
  }

  const Hotspot hotspot = findHotspotCenter(maxValue);

  updateThermalTracking(hotspot);

  if (streamMode) {
    normalizeFrame(minValue, maxValue);
    applyRowBandCorrection();
    sendFrame(minValue, maxValue, hotspot);
  } else if (millis() - lastDiagnosticFrameMs > 500) {
    lastDiagnosticFrameMs = millis();
    printDiagnosticFrame(minValue, maxValue, hotspot);
  }
}
